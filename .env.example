# Compose / runtime
PORT=28080
HOST_PORT=38080
DEBUG_HOST_PORT=48080
REQUEST_TIMEOUT=20m
MINFO_IMAGE=minfo-local
MINFO_CONTAINER_NAME=minfo-local
MINFO_DEBUG_IMAGE=minfo-debug
MINFO_DEBUG_CONTAINER_NAME=minfo-debug

# Optional Basic Auth
WEB_USERNAME=
WEB_PASSWORD=

# Frontend dev
WEBUI_PORT=48081
VITE_API_TARGET=http://127.0.0.1:48080

# Debugger
DLV_HOST_PORT=2345

# Remote release
REMOTE_SSH_HOST=
REMOTE_SSH_USER=root
REMOTE_SSH_PORT=22
REMOTE_DEPLOY_DIR=/opt/minfo

# Optional media mounts
MEDIA_PATH_1=./test-media
